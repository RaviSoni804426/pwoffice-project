<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= document.filename %> - PW Office Editor</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body style="height: 100vh; width: 100vw; margin: 0; padding: 0; overflow: hidden; background-color: #f4f5f7; position: relative;">

    <div class="editor-back-nav" style="height: 48px; position: absolute; top: 0; left: 0; right: 0; z-index: 10; box-sizing: border-box; display: flex; align-items: center; justify-content: space-between; padding: 0 1rem;">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/workspace/<%= document.workspace_id %>" class="btn btn-secondary" style="padding: 0.35rem 0.8rem; font-size: 0.85rem;">
                &larr; Back to Dashboard
            </a>
            <span class="editor-doc-title" style="font-size: 0.95rem; font-weight: 600;"><%= document.filename %></span>
        </div>
        <div style="font-size: 0.8rem; color: var(--text-secondary);">
            Powered by PW Office Editor Engine
        </div>
    </div>

    <!-- PWOFFICE Editor Container -->
    <div id="iframeEditor" style="position: absolute; top: 48px; bottom: 0; left: 0; right: 0; width: 100%; height: calc(100vh - 48px); border: none; background-color: #ffffff;"></div>
    <div id="fallback-message" style="display: none; padding: 3rem; text-align: center; flex: 1;">
        <h2 style="color: var(--primary); margin-bottom: 1rem;">Editor Temporarily Unavailable</h2>
        <p style="max-width: 600px; margin: 0 auto 1.5rem;">The document editing service is still starting up or temporarily unreachable. This usually resolves within a few seconds.</p>
        <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 2rem;">Your documents are safe. Please try refreshing the page in a moment.</p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
            <a href="" onclick="location.reload(); return false;" class="btn btn-primary">Refresh Page</a>
            <a href="/workspace/<%= document.workspace_id %>" class="btn btn-secondary">Return to Dashboard</a>
        </div>
    </div>

    <!-- Load PWOFFICE Document Server JavaScript API dynamically -->
    <script type="text/javascript">
        // Load PWOFFICE configuration
        const config = <%- JSON.stringify(config) %>;
        
        // Load the API script dynamically with proper error handling
        function loadApiScript() {
            const script = document.createElement('script');
            script.type = 'text/javascript';
            script.src = '<%= docServerUrl %>/web-apps/apps/api/documents/api.js';
            script.async = true;
            
            script.onload = function() {
                console.log('API script loaded successfully');
                initEditor();
            };
            
            script.onerror = function() {
                console.error('Failed to load API script from:', script.src);
                document.getElementById('iframeEditor').style.display = 'none';
                document.getElementById('fallback-message').style.display = 'flex';
                document.getElementById('fallback-message').style.flexDirection = 'column';
                document.getElementById('fallback-message').style.justifyContent = 'center';
            };
            
            document.head.appendChild(script);
        }
        
        // Initialize the Editor
        function initEditor() {
            try {
                if (typeof DocsAPI === 'undefined') {
                    console.error('DocsAPI is not defined even after script load.');
                    document.getElementById('iframeEditor').style.display = 'none';
                    document.getElementById('fallback-message').style.display = 'flex';
                    document.getElementById('fallback-message').style.flexDirection = 'column';
                    document.getElementById('fallback-message').style.justifyContent = 'center';
                } else {
                    console.log('DocsAPI loaded, initializing editor...');
                    const docEditor = new DocsAPI.DocEditor("iframeEditor", config);
                }
            } catch (e) {
                console.error('Failed to load PWOFFICE editor:', e);
                document.getElementById('iframeEditor').style.display = 'none';
                document.getElementById('fallback-message').style.display = 'flex';
                document.getElementById('fallback-message').style.flexDirection = 'column';
                document.getElementById('fallback-message').style.justifyContent = 'center';
            }
        }

        // Start loading the API script when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', loadApiScript);
        } else {
            loadApiScript();
        }
    </script>

  <!-- Floating Chatbot Widget -->
  <div class="chat-widget-wrapper">
    <!-- Trigger Button -->
    <button class="chat-trigger-btn" onclick="toggleChatWindow()">
      <span class="chat-icon">💬</span>
      <span class="chat-unread-dot"></span>
    </button>
    
    <!-- Chat Window -->
    <div class="chat-window-box" id="chatWindow">
      <div class="chat-window-header">
        <div class="chat-agent-info">
          <span class="chat-agent-avatar">🤖</span>
          <div>
            <h4>PW Office Editor Guide</h4>
            <span style="font-size: 0.75rem; color: #34d399; font-weight: 500;">Online • Groq Assistant</span>
          </div>
        </div>
        <button class="chat-close-btn" onclick="toggleChatWindow()">&times;</button>
      </div>
      
      <!-- Messages Container -->
      <div class="chat-messages-container" id="chatMessages">
        <div class="chat-bubble bot-msg">
          <p>Hello! I am your PW Office Editor assistant. Ask me questions about formatting, spreadsheet formulas (e.g. VLOOKUP, pivot tables), or shortcuts!</p>
          <span class="chat-time">Just now</span>
        </div>
      </div>
      
      <!-- Quick Prompts -->
      <div class="chat-quick-prompts">
        <button onclick="sendQuickPrompt('How do I write a VLOOKUP formula?')">VLOOKUP help</button>
        <button onclick="sendQuickPrompt('Explain INDEX/MATCH with an example')">INDEX/MATCH example</button>
        <button onclick="sendQuickPrompt('How do I sum column B if column A equals Yes?')">Conditional Sum</button>
      </div>
      
      <!-- Input Box -->
      <form class="chat-input-area" id="chatForm" onsubmit="handleChatSubmit(event)">
        <input type="text" id="chatInput" placeholder="Ask a formula or editing question..." required autocomplete="off">
        <button type="submit" class="chat-send-btn">Send</button>
      </form>
    </div>
  </div>

  <script>
    let chatHistory = [];

    function toggleChatWindow() {
      const chatWindow = document.getElementById('chatWindow');
      const iframeEditor = document.getElementById('iframeEditor');
      chatWindow.classList.toggle('active');
      
      // Hide unread dot when opening
      if (chatWindow.classList.contains('active')) {
        const dot = document.querySelector('.chat-unread-dot');
        if (dot) dot.style.display = 'none';
        document.getElementById('chatInput').focus();
        // Reduce iframe pointer events when chat is open to ensure chat is clickable
        if (iframeEditor) iframeEditor.style.pointerEvents = 'none';
      } else {
        // Restore iframe pointer events when chat is closed
        if (iframeEditor) iframeEditor.style.pointerEvents = 'auto';
      }
    }

    function appendMessage(role, text) {
      const chatMessages = document.getElementById('chatMessages');
      const bubble = document.createElement('div');
      bubble.className = `chat-bubble ${role === 'user' ? 'user-msg' : 'bot-msg'}`;
      
      const p = document.createElement('pre');
      p.style.whiteSpace = 'pre-wrap';
      p.style.fontFamily = 'inherit';
      p.style.margin = '0';
      p.textContent = text;
      bubble.appendChild(p);
      
      const timeSpan = document.createElement('span');
      timeSpan.className = 'chat-time';
      timeSpan.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      bubble.appendChild(timeSpan);
      
      chatMessages.appendChild(bubble);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function showTypingIndicator() {
      const chatMessages = document.getElementById('chatMessages');
      const typing = document.createElement('div');
      typing.className = 'chat-bubble bot-msg typing-indicator';
      typing.id = 'typingIndicator';
      typing.innerHTML = '<p>Assistant is typing<span>.</span><span>.</span><span>.</span></p>';
      chatMessages.appendChild(typing);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function removeTypingIndicator() {
      const indicator = document.getElementById('typingIndicator');
      if (indicator) {
        indicator.remove();
      }
    }

    function sendQuickPrompt(promptText) {
      appendMessage('user', promptText);
      sendMessageToBackend(promptText);
    }

    async function handleChatSubmit(event) {
      event.preventDefault();
      const chatInput = document.getElementById('chatInput');
      const text = chatInput.value.trim();
      if (!text) return;
      
      chatInput.value = '';
      appendMessage('user', text);
      await sendMessageToBackend(text);
    }

    async function sendMessageToBackend(messageText) {
      showTypingIndicator();
      
      // Add user message to local history array
      chatHistory.push({ role: 'user', content: messageText });
      
      try {
        const response = await fetch('/api/chat', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ 
            messages: chatHistory,
            context: 'editor'
          })
        });
        
        const data = await response.json();
        removeTypingIndicator();
        
        if (data.response) {
          appendMessage('assistant', data.response);
          chatHistory.push({ role: 'assistant', content: data.response });
        } else {
          appendMessage('assistant', 'Sorry, I received an invalid response. Please try again.');
        }
      } catch (err) {
        removeTypingIndicator();
        appendMessage('assistant', 'Network error. Please make sure the server is running.');
        console.error('Chat widget error:', err);
      }
    }
  </script>
</body>
</html>

<%- include('partials/header') %>

<div class="form-container" style="text-align: center; max-width: 500px; padding: 4rem 2rem; margin: 4rem auto;">
  <div style="font-size: 6rem; font-weight: 800; background: linear-gradient(135deg, #ff416c 0%, #ff4b2b 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1; margin-bottom: 1.5rem; letter-spacing: -2px;">
    <%= statusCode %>
  </div>
  <h2 style="font-size: 1.8rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem;"><%= title %></h2>
  <p style="color: var(--text-secondary); font-size: 1rem; line-height: 1.6; margin-bottom: 2rem;"><%= message %></p>
  
  <div>
    <a href="/" class="btn btn-primary" style="text-decoration: none; padding: 0.75rem 2rem; border-radius: 8px; font-weight: 600;">Go Back Home</a>
  </div>
</div>

<%- include('partials/footer') %>

<%- include('partials/header') %>

<div class="dashboard-header">
  <div>
    <a href="/workspaces" style="font-size: 0.9rem; display: flex; align-items: center; gap: 0.25rem; margin-bottom: 0.5rem;">
      &larr; Back to Workspaces
    </a>
    <h1><%= workspace.name %> Dashboard</h1>
  </div>
  <div class="dashboard-actions">
    <button class="btn btn-primary" onclick="openModal('createModal')">+ Create Document</button>
  </div>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="dashboard-columns">
  <!-- Left Side: Documents Table -->
  <div class="documents-card">
    <h3 class="card-title">Files</h3>
    
    <% if (documents.length === 0) { %>
      <div class="empty-state">
        <div class="empty-state-icon">📂</div>
        <h3>No files in this workspace yet</h3>
        <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Create a new document or upload an existing file to get started.</p>
        <button class="btn btn-primary" onclick="openModal('createModal')">Create First File</button>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="doc-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Owner</th>
              <th>Last Modified</th>
              <th style="text-align: right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% documents.forEach(function(doc) { %>
              <tr>
                <td>
                  <div class="doc-name-cell">
                    <% if (doc.file_type === 'docx') { %>
                      <span class="doc-icon docx">📄</span>
                    <% } else if (doc.file_type === 'xlsx') { %>
                      <span class="doc-icon xlsx">📊</span>
                    <% } else if (doc.file_type === 'pptx') { %>
                      <span class="doc-icon pptx">📽️</span>
                    <% } %>
                    <a href="/editor/<%= doc.id %>" style="font-weight: 500; color: #ffffff;"><%= doc.filename %></a>
                  </div>
                </td>
                <td style="color: var(--text-secondary); font-size: 0.9rem;"><%= doc.owner_name %></td>
                <td style="color: var(--text-secondary); font-size: 0.9rem;">
                  <%= new Date(doc.last_modified).toLocaleString() %>
                </td>
                <td style="text-align: right;">
                  <div style="display: inline-flex; gap: 0.5rem; justify-content: flex-end;">
                    <a href="/editor/<%= doc.id %>" class="btn btn-primary" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Open</a>
                    <form action="/workspace/<%= workspace.id %>/delete/<%= doc.id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this document? This cannot be undone.');" style="margin: 0;">
                      <button type="submit" class="btn btn-danger" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Right Side: Fast Upload -->
  <div class="actions-card">
    <div class="upload-section">
      <h4>Upload Local File</h4>
      <p style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: 1rem;">Supports ONLYOFFICE formats (.docx, .xlsx, .pptx).</p>
      
      <form action="/workspace/<%= workspace.id %>/upload" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <input type="file" name="file" class="form-control" required style="padding: 0.5rem; font-size: 0.85rem;">
        </div>
        <button type="submit" class="btn btn-secondary" style="width: 100%; margin-top: 0.5rem;">Upload File</button>
      </form>
    </div>
  </div>
</div>

<!-- Create File Modal -->
<div class="modal" id="createModal">
  <div class="modal-content">
    <div class="modal-header">
      <h3>Create New File</h3>
      <button class="modal-close" onclick="closeModal('createModal')">&times;</button>
    </div>
    <form action="/workspace/<%= workspace.id %>/create" method="POST">
      <div class="form-group">
        <label for="filename">Filename</label>
        <input type="text" id="filename" name="filename" class="form-control" placeholder="Project Plan" required autofocus>
      </div>
      
      <div class="form-group">
        <label for="file_type">File Type</label>
        <select id="file_type" name="file_type" class="form-control" required>
          <option value="docx">Word Document (.docx)</option>
          <option value="xlsx">Spreadsheet (.xlsx)</option>
          <option value="pptx">Presentation (.pptx)</option>
        </select>
      </div>
      
      <div class="form-actions" style="display: flex; gap: 0.5rem;">
        <button type="button" class="btn btn-secondary" onclick="closeModal('createModal')" style="flex: 1;">Cancel</button>
        <button type="submit" class="btn btn-primary" style="flex: 1;">Create</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openModal(id) {
    document.getElementById(id).classList.add('active');
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('active');
  }
</script>

<%- include('partials/footer') %>
